# agds-hr environment variables
#
# This file lives at the REPO ROOT. Local dev (`bun run dev`) loads it via
# scripts/dev/vite.mjs (--env-file + CLOUDFLARE_INCLUDE_PROCESS_ENV) so secrets
# reach the Cloudflare Worker runtime; wrangler.jsonc is under apps/web and does
# not read this file on its own.
#
# This file is the committed catalogue of every environment variable the
# codebase reads. Secrets never get real values here. The typed manifest in
# packages/env/src/manifest.ts is the system of record; `bun run check:env`
# gates three-way drift between the manifest, this file, and actual env reads
# in code. Nothing validates env at import time — the app boots with a
# feature's vars unset and fails with a self-diagnosing error only when the
# feature is exercised.

# --- Database (Neon Postgres, EU region) -------------------------------------
# Four runtime login roles plus the migration owner, each with its own
# connection string. The roles are created once per Neon branch by
# scripts/db/setup-roles.sql (run as the project owner). Per-developer Neon
# branches; no local Docker. Grants ship inside migrations, so the role split
# is enforced at the SQL layer — see docs/decisions/2026-07-02-database-roles-and-migrations.md.
#
# Obtain: create a Neon branch, run setup-roles.sql on it, then fill each URL
# with the matching role's credentials (same host/db, different user).

# Normal runtime (app_role, pool 10)
DATABASE_URL=

# Privileged app actions — auth CRUD, cross-user writes (admin_role, pool 5)
DATABASE_URL_ADMIN=

# Read-only surfaces, agent/MCP telemetry queries (readonly_role, pool 10)
DATABASE_URL_READONLY=

# Inbound webhook receivers, outbox relay (webhook_role, pool 5)
DATABASE_URL_WEBHOOK=

# Neon project owner — used only by drizzle-kit (db:generate/db:migrate) and
# one-time SQL such as setup-roles.sql. Never read by the app at runtime.
DATABASE_URL_MIGRATE=

# --- Auth (BetterAuth, SSO-only) ---------------------------------------------
# BetterAuth runs as a library inside apps/web on the admin connection and owns
# the `auth` schema. SSO-only: no email/password, no self-service sign-up. The
# Google Workspace allow-list is a hardcoded constant in packages/auth, NOT an
# env var (the code is the system of record) — see
# docs/decisions/2026-07-02-auth-identity-session-and-policy.md.
# Nothing validates at import; auth fails only when exercised without these.

# Session signing secret (required to serve auth). Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Explicit base URL — set for local dev and each Cloudflare environment
# (production custom domain and *.workers.dev previews). Optional when unset
# only if BetterAuth can infer the origin from the request. See
# docs/decisions/2026-07-03-cloudflare-hosting.md.
BETTER_AUTH_URL=

# Google Workspace SSO credentials (Google Cloud console → OAuth client).
# Optional: the Google provider is only wired when both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Dev only ----------------------------------------------------------------
# DEV_LOGIN=1 enables a local dev-login bypass (seeds a dev@albertschool.com
# developer and mints a dev session cookie) so the authenticated frame can be
# viewed without Google SSO. Fail closed: honored ONLY when set to exactly "1";
# NEVER set in production. See apps/web/src/server/dev-login.impl.server.ts.
DEV_LOGIN=

# --- Integrations ------------------------------------------------------------
# Albert Inside API service key — sent as X-API-Key to
# https://api-inside.albertschool.com; resolves to a synthetic ADMIN caller.
# Optional: the People directory falls back to an empty state when unset.
# Populates the directory from Inside's admin/officer roster. See
# docs/integrations/albert-inside-api-admin-and-organigram.md.
INSIDE_API_KEY=

# --- Email (Resend) ------------------------------------------------------------
# Transactional email for review-cycle notifications (peer-request nudges,
# assessment-ready alerts, the weekly digest) — docs/plans/notifications.md and
# docs/decisions/2026-07-04-notifications-and-cycle-tracking.md. The sender
# address is pinned in code (packages/integrations/resend); sending requires the
# one-time Resend domain verification (DNS records for albertschool.com).
# Optional: the outbox accumulates rows regardless; the drain job sends them
# once configured.

# Resend API key (https://resend.com/api-keys).
RESEND_API_KEY=

# FAIL CLOSED: email is dry-run (logged, not sent) unless this is exactly
# "false". Only production sets it — a dev worktree pointed at real data must
# never mail real people.
EMAIL_DRY_RUN=

# --- Cron ----------------------------------------------------------------------
# Bearer secret guarding the manual cron runner (/api/cron/run/<jobId>).
# Cloudflare Cron Triggers invoke the Worker's scheduled handler directly and
# do not need it; the HTTP route exists for manual runs and fails closed (503)
# when unset. Generate: openssl rand -hex 32
CRON_SECRET=

# --- Deploy -------------------------------------------------------------------
# Cloudflare API token for scripts/ops/deploy-worker.ts and CI deploy
# (deploy-time only, never read at runtime). Create with Workers Scripts:Edit
# + Hyperdrive:Edit. Also add as the CLOUDFLARE_API_TOKEN GitHub Actions secret.
CLOUDFLARE_API_TOKEN=

# Local-dev targets for the Hyperdrive bindings in apps/web/wrangler.jsonc.
# Read by wrangler/miniflare during `bun run dev`, never by app code (so they
# are intentionally absent from ENV_MANIFEST — check:env skips comments). Set
# each to the same value as the matching DATABASE_URL* var above:
#   CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE_APP
#   CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE_ADMIN
#   CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE_READONLY
#   CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE_WEBHOOK
