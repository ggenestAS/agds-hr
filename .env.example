# agds-hr environment variables
#
# This file is the committed catalogue of every environment variable the
# codebase reads. Secrets never get real values here. The typed manifest in
# packages/env/src/manifest.ts is the system of record; `bun run check:env`
# gates three-way drift between the manifest, this file, and actual env reads
# in code. Nothing validates env at import time — the app boots with a
# feature's vars unset and fails with a self-diagnosing error only when the
# feature is exercised.

# --- Database (Neon Postgres, EU region) -------------------------------------
# Four runtime login roles plus the migration owner, each with its own
# connection string. The roles are created once per Neon branch by
# scripts/db/setup-roles.sql (run as the project owner). Per-developer Neon
# branches; no local Docker. Grants ship inside migrations, so the role split
# is enforced at the SQL layer — see docs/decisions/2026-07-02-database-roles-and-migrations.md.
#
# Obtain: create a Neon branch, run setup-roles.sql on it, then fill each URL
# with the matching role's credentials (same host/db, different user).

# Normal runtime (app_role, pool 10)
DATABASE_URL=

# Privileged app actions — auth CRUD, cross-user writes (admin_role, pool 5)
DATABASE_URL_ADMIN=

# Read-only surfaces, agent/MCP telemetry queries (readonly_role, pool 10)
DATABASE_URL_READONLY=

# Inbound webhook receivers, outbox relay (webhook_role, pool 5)
DATABASE_URL_WEBHOOK=

# Neon project owner — used only by drizzle-kit (db:generate/db:migrate) and
# one-time SQL such as setup-roles.sql. Never read by the app at runtime.
DATABASE_URL_MIGRATE=
