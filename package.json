{
  "name": "agds-hr",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/domains/*",
    "packages/integrations/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "node scripts/dev/vite.mjs dev",
    "build": "node scripts/dev/vite.mjs build",
    "deploy": "bun --filter @agds-hr/web deploy",
    "deploy:prod": "bun --env-file=.env scripts/ops/deploy-worker.ts",
    "preview": "node scripts/dev/vite.mjs preview",
    "lint": "oxlint --type-aware --type-check .",
    "lint:staged": "bun run scripts/ci/lint-staged.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check:docs": "bun run scripts/ci/check-docs.ts",
    "check:migrations": "bun run scripts/ci/check-migrations.ts",
    "check:env": "bun run scripts/ci/check-env.ts",
    "check:nav": "bun run scripts/ci/check-nav.ts",
    "check:theme": "bun run scripts/ci/check-theme.ts",
    "check:client-barrels": "bun run scripts/ci/check-client-barrels.ts",
    "test": "bun test",
    "test:unit": "bun test --test-name-pattern \"^(?!.*\\[integration\\])\"",
    "test:staged": "bun run scripts/ci/test-staged.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "drizzle-kit": "beta",
    "drizzle-orm": "^1.0.0-beta.22",
    "knip": "^5.44.0",
    "lefthook": "^1.13.6",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "zod": "^4.1.0"
  }
}
